---
import '../styles/global.css';

interface Props {
	title?: string;
	description?: string;
}

const {
	title = 'Slashtalk — coordination, without the meetings.',
	description = "A floating dock that shows what your team is shipping. Recent PRs, live coding sessions, file conflicts before they happen. Built for small remote teams that move fast.",
} = Astro.props;

// og:image and twitter:image must be absolute URLs — relative paths break
// previews on Facebook, X/Twitter, LinkedIn, Slack, Discord, etc.
// Astro.site comes from `site` in astro.config.mjs (overridable via SITE_URL).
const ogImage = new URL('/og-image.png', Astro.site).toString();
// Branded 600x315 unfurl card (Slashtalk logo + wordmark). Width/height
// are emitted as og:image:width / og:image:height so unfurlers don't
// have to fetch the asset just to size the card. If you replace the file,
// keep the dimensions in sync below.
const ogImageWidth = 600;
const ogImageHeight = 315;
const canonicalUrl = new URL(Astro.url.pathname, Astro.site).toString();
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<meta name="generator" content={Astro.generator} />
		<meta name="description" content={description} />
		<link rel="canonical" href={canonicalUrl} />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:type" content="website" />
		<meta property="og:url" content={canonicalUrl} />
		<meta property="og:image" content={ogImage} />
		<meta property="og:image:width" content={String(ogImageWidth)} />
		<meta property="og:image:height" content={String(ogImageHeight)} />
		<meta property="og:image:alt" content="Slashtalk" />
		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:title" content={title} />
		<meta name="twitter:description" content={description} />
		<meta name="twitter:image" content={ogImage} />
		<meta name="twitter:image:alt" content="Slashtalk" />
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link
			href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Instrument+Serif:ital@0;1&display=swap"
			rel="stylesheet"
		/>
		<title>{title}</title>
	</head>
	<body class="bg-white text-neutral-900 antialiased">
		<slot />
	</body>
</html>
