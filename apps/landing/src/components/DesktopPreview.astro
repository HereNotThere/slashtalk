<script is:inline define:vars={{ team }}>
	const STATE_COLOR = {
		open: "text-emerald-600",
		merged: "text-blue-600",
		closed: "text-red-600",
	};

	const teamByLogin = new Map(team.map((m) => [m.login, m]));

	function escapeHtml(s) {
		return String(s).replace(/[&<>"']/g, (c) =>
			c === "&" ? "&amp;" : c === "<" ? "&lt;" : c === ">" ? "&gt;" : c === '"' ? "&quot;" : "&#39;",
		);
	}

	document.querySelectorAll(".desktop-preview").forEach((stage) => {
		const dock = stage.querySelector(".macdock");
		const card = stage.querySelector("[data-card]");
		const stageInner = stage; // positioning context = the desktop window itself
		const hint = stage.querySelector("[data-hint]");
		if (!dock || !card) return;

		// Search button: scroll to the Ask section.
		const searchBtn = dock.querySelector("[data-search]");
		if (searchBtn) {
			searchBtn.addEventListener("click", (e) => {
				e.preventDefault();
				const target = document.getElementById("ask");
				if (!target) return;
				const top = target.getBoundingClientRect().top + window.scrollY - 24;
				window.scrollTo({ top, behavior: "smooth" });
			});
		}

		// --- Dragging + edge snapping ----------------------------------------

		let dragging = false;
		let pointerId = null;
		let startX = 0;
		let startY = 0;
		let dockStartLeft = 0;
		let dockStartTop = 0;
		let dragMoved = false;
		let openLogin = null;
		let hideTimer = null;
		const dropzone = stage.querySelector("[data-dropzone]");
		const EDGE_OFFSET = 24;

		// Snapshot the dock's natural horizontal dimensions so we can mirror
		// them in vertical mode (and size the dropzone to match).
		const initRect = dock.getBoundingClientRect();
		const HBASE_W = initRect.width;
		const HBASE_H = initRect.height;

		function dockSizeForEdge(edge) {
			if (edge === "left" || edge === "right") {
				// Vertical dock — the long axis equals the horizontal width;
				// the short axis equals the horizontal height.
				return { w: HBASE_H, h: HBASE_W };
			}
			return { w: HBASE_W, h: HBASE_H };
		}

		function dropTargetForEdge(edge, sr) {
			const { w, h } = dockSizeForEdge(edge);
			let left = 0;
			let top = 0;
			if (edge === "bottom") {
				left = (sr.width - w) / 2;
				top = sr.height - h - EDGE_OFFSET;
			} else if (edge === "top") {
				left = (sr.width - w) / 2;
				top = EDGE_OFFSET;
			} else if (edge === "left") {
				left = EDGE_OFFSET;
				top = (sr.height - h) / 2;
			} else {
				left = sr.width - w - EDGE_OFFSET;
				top = (sr.height - h) / 2;
			}
			return { left, top, w, h };
		}

		function nearestEdge(cx, cy, sr) {
			const distLeft = cx;
			const distRight = sr.width - cx;
			const distTop = cy;
			const distBottom = sr.height - cy;
			const min = Math.min(distLeft, distRight, distTop, distBottom);
			if (min === distLeft) return "left";
			if (min === distRight) return "right";
			if (min === distTop) return "top";
			return "bottom";
		}

		function showDropzone(edge, sr) {
			const t = dropTargetForEdge(edge, sr);
			dropzone.style.width = t.w + "px";
			dropzone.style.height = t.h + "px";
			dropzone.style.left = t.left + "px";
			dropzone.style.top = t.top + "px";
			dropzone.classList.remove("hidden");
		}

		function hideDropzone() {
			dropzone.classList.add("hidden");
		}

		function setEdge(edge) {
			const sr = stageInner.getBoundingClientRect();
			const t = dropTargetForEdge(edge, sr);
			dock.dataset.edge = edge;
			dock.style.transition = "left 240ms cubic-bezier(.4,0,.2,1), top 240ms cubic-bezier(.4,0,.2,1)";
			dock.style.right = "";
			dock.style.bottom = "";
			dock.style.transform = "none";
			dock.style.left = t.left + "px";
			dock.style.top = t.top + "px";
			dock.classList.remove("flex-col", "flex-row");
			dock.classList.add(edge === "left" || edge === "right" ? "flex-col" : "flex-row");
			window.setTimeout(() => (dock.style.transition = ""), 260);
		}

		function onPointerDown(e) {
			// Skip drag start for interactive children — let the avatar / search
			// button receive their normal click + hover events.
			if (e.target.closest(".avatar") || e.target.closest("[data-search]")) return;
			dragging = true;
			dragMoved = false;
			pointerId = e.pointerId;
			startX = e.clientX;
			startY = e.clientY;
			const r = dock.getBoundingClientRect();
			const sr = stageInner.getBoundingClientRect();
			dockStartLeft = r.left - sr.left;
			dockStartTop = r.top - sr.top;
			dock.setPointerCapture(e.pointerId);
			dock.style.transition = "none";
			// Switch to pure pixel positioning — strip the initial Tailwind
			// `left-1/2` + `-translate-x-1/2` so subsequent left/top inline
			// styles aren't offset by a half-width translate.
			dock.classList.remove("left-1/2", "-translate-x-1/2");
			dock.style.transform = "none";
			dock.style.left = dockStartLeft + "px";
			dock.style.top = dockStartTop + "px";
			hideCard();
			if (hint) hint.style.opacity = "0";
		}

		function onPointerMove(e) {
			if (!dragging || e.pointerId !== pointerId) return;
			const dx = e.clientX - startX;
			const dy = e.clientY - startY;
			if (!dragMoved && Math.hypot(dx, dy) < 4) return;
			dragMoved = true;
			const sr = stageInner.getBoundingClientRect();
			dock.style.transform = "";
			dock.style.right = "";
			dock.style.bottom = "";
			dock.style.left = dockStartLeft + dx + "px";
			dock.style.top = dockStartTop + dy + "px";
			// Live-update the drop zone outline at the nearest edge.
			const r = dock.getBoundingClientRect();
			const cx = r.left + r.width / 2 - sr.left;
			const cy = r.top + r.height / 2 - sr.top;
			showDropzone(nearestEdge(cx, cy, sr), sr);
		}

		function onPointerUp(e) {
			if (!dragging || e.pointerId !== pointerId) return;
			dragging = false;
			pointerId = null;
			hideDropzone();
			if (!dragMoved) return; // treat as click — leave position alone
			const sr = stageInner.getBoundingClientRect();
			const r = dock.getBoundingClientRect();
			const cx = r.left + r.width / 2 - sr.left;
			const cy = r.top + r.height / 2 - sr.top;
			setEdge(nearestEdge(cx, cy, sr));
		}

		dock.addEventListener("pointerdown", onPointerDown);
		dock.addEventListener("pointermove", onPointerMove);
		dock.addEventListener("pointerup", onPointerUp);
		dock.addEventListener("pointercancel", onPointerUp);

		// --- Hover card ------------------------------------------------------

		function renderCard(m) {
			card.querySelector("[data-card-avatar]").src = `https://avatars.githubusercontent.com/u/${m.id}?s=120&v=4`;
			card.querySelector("[data-card-name]").textContent = m.login;
			card.querySelector("[data-card-weather]").textContent = m.weather;
			card.querySelector("[data-card-city]").textContent = m.city;
			card.querySelector("[data-card-time]").textContent = m.time;
			card.querySelector("[data-card-tokens]").textContent = m.tokens + "M";
			card.querySelector("[data-card-now]").textContent = m.now;
			card.querySelector("[data-card-repo]").textContent = m.repo;
			card.querySelector("[data-card-branch]").textContent = m.branch;
			card.querySelector("[data-card-age]").textContent = m.age;
			card.querySelector("[data-card-today]").textContent = m.today || "—";
			const prsRoot = card.querySelector("[data-card-prs]");
			prsRoot.innerHTML = m.prs
				.map(
					(pr) => `
				<div class="flex items-start gap-2 rounded-md px-1.5 py-1.5">
					<svg class="mt-0.5 size-3.5 shrink-0 ${STATE_COLOR[pr.state]}" viewBox="0 0 16 16" fill="currentColor" aria-hidden>
						<path d="M1.5 3.25a2.25 2.25 0 1 1 3 2.122v5.256a2.251 2.251 0 1 1-1.5 0V5.372A2.25 2.25 0 0 1 1.5 3.25Zm5.677-.177L9.573.677A.25.25 0 0 1 10 .854V2.5h1A2.5 2.5 0 0 1 13.5 5v5.628a2.251 2.251 0 1 1-1.5 0V5a1 1 0 0 0-1-1h-1v1.646a.25.25 0 0 1-.427.177L7.177 3.427a.25.25 0 0 1 0-.354ZM3.75 2.5a.75.75 0 1 0 0 1.5.75.75 0 0 0 0-1.5Zm0 9.5a.75.75 0 1 0 0 1.5.75.75 0 0 0 0-1.5Zm8.25.75a.75.75 0 1 0 1.5 0 .75.75 0 0 0-1.5 0Z" />
					</svg>
					<div class="min-w-0 flex-1">
						<div class="truncate text-xs text-neutral-800">${escapeHtml(pr.title)}</div>
						<div class="mt-0.5 flex items-center gap-1.5 text-[10px] text-neutral-500">
							<span class="font-mono ${STATE_COLOR[pr.state]}">#${pr.number}</span>
							<span class="text-neutral-300">·</span>
							<span>${pr.state}</span>
							<span class="text-neutral-300">·</span>
							<span>${escapeHtml(pr.age)}</span>
						</div>
					</div>
				</div>
			`,
				)
				.join("");
		}

		function positionCard(avatar) {
			const sr = stageInner.getBoundingClientRect();
			const ar = avatar.getBoundingClientRect();
			const edge = dock.dataset.edge || "bottom";
			const cw = card.offsetWidth;
			const ch = card.offsetHeight;
			let left = 0;
			let top = 0;
			const gap = 14;
			if (edge === "bottom") {
				left = ar.left + ar.width / 2 - sr.left - cw / 2;
				top = ar.top - sr.top - ch - gap;
			} else if (edge === "top") {
				left = ar.left + ar.width / 2 - sr.left - cw / 2;
				top = ar.bottom - sr.top + gap;
			} else if (edge === "left") {
				left = ar.right - sr.left + gap;
				top = ar.top + ar.height / 2 - sr.top - ch / 2;
			} else {
				left = ar.left - sr.left - cw - gap;
				top = ar.top + ar.height / 2 - sr.top - ch / 2;
			}
			const margin = 12;
			left = Math.max(margin, Math.min(sr.width - cw - margin, left));
			top = Math.max(margin, Math.min(sr.height - ch - margin, top));
			card.style.left = left + "px";
			card.style.top = top + "px";
		}

		function showCard(login, avatar) {
			const m = teamByLogin.get(login);
			if (!m) return;
			if (hideTimer) {
				clearTimeout(hideTimer);
				hideTimer = null;
			}
			openLogin = login;
			renderCard(m);
			card.classList.remove("hidden");
			requestAnimationFrame(() => positionCard(avatar));
		}

		function hideCard() {
			openLogin = null;
			card.classList.add("hidden");
			card.style.display = "";
		}

		function scheduleHide() {
			if (hideTimer) clearTimeout(hideTimer);
			hideTimer = window.setTimeout(hideCard, 160);
		}

		stage.querySelectorAll(".avatar").forEach((avatar) => {
			const login = avatar.dataset.user;
			if (!login) return;
			avatar.addEventListener("mouseenter", () => showCard(login, avatar));
			avatar.addEventListener("mouseleave", scheduleHide);
			avatar.addEventListener("focus", () => showCard(login, avatar));
			avatar.addEventListener("blur", scheduleHide);
		});

		card.addEventListener("mouseenter", () => {
			if (hideTimer) {
				clearTimeout(hideTimer);
				hideTimer = null;
			}
		});
		card.addEventListener("mouseleave", scheduleHide);

		window.addEventListener("resize", () => {
			if (!openLogin) return;
			const av = stage.querySelector(`.avatar[data-user="${openLogin}"]`);
			if (av) positionCard(av);
		});
	});
</script>

<style>
	.dock-live {
		box-shadow: 0 0 0 2px rgba(59, 130, 246, 0.9);
		animation: dock-live-pulse 2s ease-in-out infinite;
	}

	@keyframes dock-live-pulse {
		0%,
		100% {
			box-shadow: 0 0 0 2px rgba(59, 130, 246, 0.9);
		}
		50% {
			box-shadow: 0 0 0 4px rgba(59, 130, 246, 0.9);
		}
	}

	@media (prefers-reduced-motion: reduce) {
		.dock-live {
			animation: none;
		}
	}

	.macdock {
		touch-action: none;
	}
</style>
