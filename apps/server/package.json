{
  "name": "@slashtalk/server",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun run --watch src/index.ts",
    "start": "bun run src/index.ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "lint": "eslint .",
    "spike:mcp-oauth": "bun run scripts/mcp-oauth-discovery-spike.ts",
    "gen:db-schema": "bun run scripts/gen-db-schema.ts",
    "gen:db-schema:check": "bun run scripts/gen-db-schema.ts -- --check"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.118",
    "@anthropic-ai/sdk": "^0.90.0",
    "@elysiajs/cors": "^1.3.0",
    "@elysiajs/jwt": "^1.3.0",
    "@elysiajs/openapi": "^1.3.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@slashtalk/shared": "workspace:*",
    "drizzle-orm": "^0.43.0",
    "drizzle-typebox": "^0.2.0",
    "elysia": "^1.3.0",
    "ioredis": "^5.6.0",
    "postgres": "^3.4.0",
    "zod": "^4"
  },
  "devDependencies": {
    "@eslint/js": "^9.13.0",
    "@types/bun": "^1.2.0",
    "drizzle-kit": "^0.31.0",
    "eslint": "^9.13.0",
    "globals": "^15.11.0",
    "typescript": "^5.8.0",
    "typescript-eslint": "^8.10.0"
  }
}
