		<slot />
	</div>

	<div
		class="dropzone pointer-events-none absolute z-20 hidden rounded-full border-2 border-dashed border-neutral-400/70 bg-neutral-300/20 backdrop-blur-sm transition-opacity"
		data-dropzone
		aria-hidden="true"
	></div>

