	title: string;
	number: number;
	state: "open" | "merged" | "closed";
	age: string;
}

interface Member {
	login: string;
	id: number;
	label: string;
	live?: boolean;
	city: string;
	weather: string; // emoji
	time: string;
	tokens: string;
	now: string;
	today: string;
	repo: string;
	branch: string;
	age: string;
	prs: PrSeed[];
}

