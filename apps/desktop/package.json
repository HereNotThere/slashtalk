{
  "name": "@slashtalk/electron",
  "version": "0.1.1",
  "private": true,
  "description": "slashtalk electron app",
  "type": "module",
  "main": "./out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "start": "electron-vite preview",
    "dist": "electron-vite build && electron-builder --publish never",
    "dist:mac": "electron-vite build && electron-builder --mac --publish never",
    "dist:mac:unsigned": "electron-vite build && electron-builder --mac --publish never --config.mac.identity=null --config.mac.notarize=false",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json",
    "typecheck:web": "tsc --noEmit -p tsconfig.web.json",
    "typecheck": "bun run typecheck:node && bun run typecheck:web",
    "test": "bun test",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix"
  },
  "build": {
    "appId": "com.slashtalk.desktop",
    "productName": "Slashtalk",
    "electronVersion": "33.4.11",
    "directories": {
      "output": "dist"
    },
    "files": [
      "out/**/*",
      "resources/**/*",
      "package.json"
    ],
    "asar": true,
    "npmRebuild": false,
    "electronUpdaterCompatibility": ">=2.16",
    "publish": [
      {
        "provider": "github",
        "owner": "HereNotThere",
        "repo": "slashtalk",
        "releaseType": "release"
      }
    ],
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "universal"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "universal"
          ]
        }
      ],
      "artifactName": "${productName}-mac-${arch}.${ext}",
      "category": "public.app-category.productivity",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.plist",
      "notarize": true
    }
  },
  "trustedDependencies": [
    "electron",
    "esbuild"
  ],
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.118",
    "@anthropic-ai/sdk": "^0.90.0",
    "@fontsource/instrument-serif": "^5.2.8",
    "@fontsource/inter": "^5.2.8",
    "@heroicons/react": "^2.2.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@slashtalk/shared": "workspace:*",
    "electron-updater": "^6.8.3",
    "koffi": "^2.16.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.13.0",
    "@tailwindcss/vite": "^4",
    "@types/node": "^22.7.5",
    "@types/react": "^18.3.11",
    "@types/react-dom": "^18.3.1",
    "@types/ws": "^8.5.12",
    "@vitejs/plugin-react": "^4.3.3",
    "electron": "^33.0.0",
    "electron-builder": "^25.1.8",
    "electron-vite": "^2.3.0",
    "eslint": "^9.13.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react": "^7.37.1",
    "eslint-plugin-react-hooks": "^5.0.0",
    "eslint-plugin-react-refresh": "^0.4.12",
    "globals": "^15.11.0",
    "tailwindcss": "^4",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.10.0",
    "vite": "^5.4.9"
  }
}
