---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Slashtalk — presence for AI-native engineering teams">
	<main class="mx-auto flex min-h-screen max-w-3xl flex-col items-start justify-center px-6 py-24">
		<span class="mb-6 inline-flex items-center rounded-full border border-neutral-800 bg-neutral-900 px-3 py-1 text-xs font-medium text-neutral-400">
			Coming soon
		</span>
		<h1 class="text-5xl font-semibold tracking-tight text-white sm:text-6xl">
			SlashTalk
		</h1>
		<p class="mt-6 max-w-xl text-lg text-neutral-400">
			Slashtalk is the presence layer for AI-native engineering teams. See
			who's shipping what, right now, without standups.
		</p>
		<div class="mt-10 flex gap-3">
			<a
				href="#"
				class="rounded-md bg-white px-4 py-2 text-sm font-medium text-neutral-950 transition hover:bg-neutral-200"
			>
				Get notified
			</a>
			<a
				href="https://slashtalk.com"
				class="rounded-md border border-neutral-800 px-4 py-2 text-sm font-medium text-neutral-200 transition hover:bg-neutral-900"
			>
				Learn more
			</a>
		</div>
	</main>
</Layout>
