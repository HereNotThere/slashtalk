# apps/web has no required environment variables.
#
# In production, the PWA is served by apps/server under /app/* and talks to the
# API with same-origin relative URLs:
#
#   /api/*
#   /auth/*
#   /ws
#
# For local development, `bun run dev:web` starts Vite and proxies those paths
# to VITE_SLASHTALK_API_URL. Leave it unset for a local backend at
# http://localhost:10000, or point it at the hosted API when you want to test
# the web shell without running apps/server locally:
#
#   bun run dev:server
#   VITE_SLASHTALK_API_URL=https://slashtalk.onrender.com
#
# Do not add JWTs, refresh tokens, device API keys, or GitHub tokens here. The
# browser app uses httpOnly cookies set by the server.
VITE_SLASHTALK_API_URL=http://localhost:10000
