---
// Static replica of the desktop info card (HierarchyDashboard.tsx).
---

<div
	class="mx-auto w-full max-w-sm overflow-hidden rounded-2xl border border-neutral-200 bg-white text-left shadow-[0_30px_60px_-30px_rgba(0,0,0,0.25)]"
>
	<div class="flex items-center justify-between gap-3 px-4 pt-4 pb-3">
		<div class="flex items-center gap-2.5">
			<img
				src="https://i.pravatar.cc/120?img=47"
				alt=""
				class="size-9 rounded-full object-cover ring-1 ring-black/5"
			/>
			<div class="leading-tight">
				<div class="text-base font-semibold text-neutral-900">ttillberg</div>
				<div class="text-xs text-neutral-500">
					Stockholm <span class="text-neutral-300">·</span> 8:16 PM
				</div>
			</div>
		</div>
		<div class="text-right text-xs text-neutral-500">24.1M tokens</div>
	</div>

	<div class="mx-4 h-px bg-neutral-200/80"></div>

	<div class="px-4 pt-3 pb-4">
		<div class="mb-1.5 flex items-center gap-1.5">
			<span class="inline-flex size-1.5 animate-pulse rounded-full bg-emerald-500"></span>
			<span class="text-[11px] font-semibold tracking-wider text-neutral-500 uppercase">Now</span>
		</div>
		<p class="text-sm leading-relaxed text-neutral-800">
			Building project dashboard summary card.
		</p>
		<div class="mt-3 flex items-center gap-2 text-xs text-neutral-500">
			<span class="font-medium text-neutral-700">slashtalk</span>
			<span class="text-neutral-300">·</span>
			<span class="font-mono text-[11px] text-neutral-600">main</span>
			<span class="text-neutral-300">·</span>
			<span>14m</span>
		</div>
	</div>

	<div class="mx-4 h-px bg-neutral-200/80"></div>

	<div class="px-4 pt-3 pb-4">
		<div class="mb-1.5 text-[11px] font-semibold tracking-wider text-neutral-500 uppercase">
			Today
		</div>
		<p class="text-sm leading-relaxed text-neutral-800">
			Merged domain-extraction refactor across 4 PRs.
		</p>
	</div>

	<div class="mx-4 h-px bg-neutral-200/80"></div>

	<div class="px-4 pt-3 pb-4">
		<div class="mb-2 text-[11px] font-semibold tracking-wider text-neutral-500 uppercase">
			PRs in review
		</div>
		<div class="space-y-2">
			<div class="flex items-start gap-2 rounded-lg px-2 py-2 hover:bg-neutral-50">
				<div
					class="mt-0.5 inline-flex size-4 items-center justify-center rounded-full bg-emerald-100 text-emerald-700"
				>
					<svg
						viewBox="0 0 16 16"
						fill="currentColor"
						width="10"
						height="10"
						aria-hidden="true"
					>
						<path
							d="M5 3.25a.75.75 0 1 1-1.5 0 .75.75 0 0 1 1.5 0Zm0 9.5a.75.75 0 1 1-1.5 0 .75.75 0 0 1 1.5 0ZM4.25 6a.75.75 0 0 0-.75.75v3.5a.75.75 0 0 0 1.5 0v-3.5A.75.75 0 0 0 4.25 6Zm7-3.25a.75.75 0 1 1-1.5 0 .75.75 0 0 1 1.5 0Zm.75 3.25a3 3 0 1 0-3.75 2.905V12a2 2 0 0 0 2 2H11a.75.75 0 0 1 0 1.5h-.75a3.5 3.5 0 0 1-3.5-3.5V8.905A3 3 0 0 1 9 3a3 3 0 0 1 3 3Z"
						></path>
					</svg>
				</div>
				<div class="min-w-0 flex-1">
					<div class="truncate text-sm text-neutral-800">
						feat(desktop): add project overview info-card
					</div>
					<div class="mt-0.5 flex items-center gap-1.5 text-[11px] text-neutral-500">
						<span class="font-mono text-neutral-600">#192</span>
						<span class="text-neutral-300">·</span>
						<span
							class="rounded-full bg-emerald-50 px-1.5 py-0.5 font-medium text-emerald-700"
							>open</span
						>
						<span class="text-neutral-300">·</span>
						<span>22m ago</span>
					</div>
				</div>
			</div>
			<div class="flex items-start gap-2 rounded-lg px-2 py-2 hover:bg-neutral-50">
				<div
					class="mt-0.5 inline-flex size-4 items-center justify-center rounded-full bg-violet-100 text-violet-700"
				>
					<svg
						viewBox="0 0 16 16"
						fill="currentColor"
						width="10"
						height="10"
						aria-hidden="true"
					>
						<path
							d="M5 3.25a.75.75 0 1 1-1.5 0 .75.75 0 0 1 1.5 0Zm0 9.5a.75.75 0 1 1-1.5 0 .75.75 0 0 1 1.5 0ZM4.25 6a.75.75 0 0 0-.75.75v3.5a.75.75 0 0 0 1.5 0v-3.5A.75.75 0 0 0 4.25 6Zm7-3.25a.75.75 0 1 1-1.5 0 .75.75 0 0 1 1.5 0Zm.75 3.25a3 3 0 1 0-3.75 2.905V12a2 2 0 0 0 2 2H11a.75.75 0 0 1 0 1.5h-.75a3.5 3.5 0 0 1-3.5-3.5V8.905A3 3 0 0 1 9 3a3 3 0 0 1 3 3Z"
						></path>
					</svg>
				</div>
				<div class="min-w-0 flex-1">
					<div class="truncate text-sm text-neutral-800">
						feat(desktop): source user-card PRs from server
					</div>
					<div class="mt-0.5 flex items-center gap-1.5 text-[11px] text-neutral-500">
						<span class="font-mono text-neutral-600">#188</span>
						<span class="text-neutral-300">·</span>
						<span
							class="rounded-full bg-violet-50 px-1.5 py-0.5 font-medium text-violet-700"
							>merged</span
						>
						<span class="text-neutral-300">·</span>
						<span>1d ago</span>
					</div>
				</div>
			</div>
		</div>
	</div>
</div>
