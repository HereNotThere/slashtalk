---
// Static replica of the desktop info card (HierarchyDashboard.tsx).
// Icons mirror the desktop's set:
//   - weather emoji from useLocationWeather
//   - ClaudeIcon (asterisk) for tokens
//   - BoltIcon (Heroicons) for the NOW header, in the same blue
//   - ClockIcon (Heroicons) for the TODAY header
//   - PrIcon (GitHub branch glyph) for the PR rows, tinted by state per
//     PR_STATE_COLOR (open=emerald, merged=blue, closed=red)

interface PrRow {
	title: string;
	number: number;
	state: "open" | "merged" | "closed";
	age: string;
}

const prs: PrRow[] = [
	{ title: "feat(desktop): add project overview info-card", number: 192, state: "open", age: "22m ago" },
	{ title: "feat(desktop): source user-card PRs from server", number: 188, state: "merged", age: "1d ago" },
	{ title: "fix(desktop): pin electronVersion for hoisted node_modules", number: 207, state: "merged", age: "2d ago" },
];

const stateColor: Record<PrRow["state"], string> = {
	open: "text-emerald-600",
	merged: "text-blue-600",
	closed: "text-red-600",
};
---

<div
	class="mx-auto w-full max-w-sm overflow-hidden rounded-2xl border border-neutral-200 bg-white text-left shadow-[0_30px_60px_-30px_rgba(0,0,0,0.25)]"
>
	<div class="flex items-start gap-3 px-4 pt-4 pb-3">
		<img
			src="https://avatars.githubusercontent.com/u/557990?s=120&v=4"
			alt=""
			class="size-10 shrink-0 rounded-full object-cover ring-1 ring-black/5"
		/>
		<div class="min-w-0 flex-1 leading-tight">
			<div class="text-lg font-bold text-neutral-900">ttillberg</div>
			<div class="mt-1 flex items-center gap-1.5 text-sm text-neutral-500">
				<span aria-hidden>☁️</span>
				<span>Stockholm</span>
				<span class="text-neutral-300">·</span>
				<span>8:16 PM</span>
			</div>
			<div class="mt-1 flex items-center gap-1.5 text-sm text-neutral-500">
				<svg width="12" height="13" viewBox="0 0 13 14" fill="currentColor" aria-hidden class="text-neutral-700">
					<path d="M 2.55 9.31 L 5.108 7.765 L 5.151 7.631 L 5.108 7.557 L 4.984 7.556 L 4.556 7.528 L 3.094 7.486 L 1.827 7.429 L 0.599 7.358 L 0.29 7.287 L 0 6.876 L 0.03 6.671 L 0.29 6.483 L 0.662 6.518 L 1.484 6.579 L 2.719 6.67 L 3.614 6.727 L 4.941 6.875 L 5.151 6.875 L 5.181 6.784 L 5.109 6.727 L 5.053 6.67 L 3.776 5.739 L 2.393 4.754 L 1.669 4.187 L 1.277 3.9 L 1.08 3.631 L 0.995 3.043 L 1.35 2.622 L 1.828 2.657 L 1.95 2.692 L 2.433 3.092 L 3.467 3.953 L 4.816 5.023 L 5.013 5.199 L 5.092 5.139 L 5.102 5.096 L 5.013 4.937 L 4.279 3.509 L 3.496 2.057 L 3.148 1.455 L 3.056 1.094 C 3.023 0.946 3 0.821 3 0.669 L 3.404 0.077 L 3.628 0 L 4.168 0.077 L 4.395 0.29 L 4.731 1.116 L 5.274 2.416 L 6.117 4.184 L 6.364 4.708 L 6.495 5.194 L 6.544 5.342 L 6.629 5.342 L 6.629 5.257 L 6.699 4.261 L 6.827 3.038 L 6.952 1.465 L 6.995 1.022 L 7.198 0.491 L 7.603 0.204 L 7.919 0.367 L 8.179 0.767 L 8.143 1.026 L 7.988 2.107 L 7.685 3.8 L 7.488 4.934 L 7.603 4.934 L 7.735 4.792 L 8.268 4.031 L 9.163 2.826 L 9.558 2.348 L 10.019 1.82 L 10.315 1.568 L 10.874 1.568 L 11.286 2.227 L 11.101 2.907 L 10.525 3.693 L 10.048 4.359 L 9.363 5.351 L 8.936 6.145 L 8.975 6.208 L 9.077 6.198 L 10.624 5.843 L 11.459 5.681 L 12.457 5.497 L 12.908 5.724 L 12.957 5.954 L 12.78 6.426 L 11.713 6.709 L 10.462 6.978 L 8.599 7.453 L 8.577 7.471 L 8.603 7.505 L 9.442 7.591 L 9.801 7.611 L 10.68 7.611 L 12.316 7.743 L 12.744 8.047 L 13 8.419 L 12.957 8.703 L 12.299 9.063 L 11.41 8.837 L 9.337 8.306 L 8.626 8.115 L 8.527 8.115 L 8.527 8.178 L 9.12 8.802 L 10.206 9.857 L 11.566 11.218 L 11.635 11.554 L 11.46 11.819 L 11.276 11.791 L 10.081 10.824 L 9.62 10.388 L 8.577 9.442 L 8.507 9.442 L 8.507 9.541 L 8.748 9.92 L 10.018 11.975 L 10.084 12.605 L 9.992 12.811 L 9.662 12.934 L 9.301 12.863 L 8.557 11.74 L 7.79 10.475 L 7.171 9.341 L 7.096 9.387 L 6.73 13.621 L 6.559 13.837 L 6.164 14 L 5.835 13.731 L 5.66 13.295 L 5.835 12.434 L 6.046 11.311 L 6.217 10.418 L 6.371 9.309 L 6.464 8.941 L 6.457 8.916 L 6.382 8.926 L 5.605 10.074 L 4.423 11.793 L 3.489 12.87 L 3.265 12.965 L 2.877 12.749 L 2.913 12.363 L 3.129 12.019 L 4.423 10.247 L 5.204 9.149 L 5.708 8.515 L 5.704 8.424 L 5.674 8.424 L 2.238 10.825 L 1.626 10.911 L 1.362 10.645 L 1.395 10.209 L 1.52 10.068 L 2.553 9.302 L 2.549 9.306 L 2.55 9.31 Z" />
				</svg>
				<span>24.1M tokens</span>
			</div>
		</div>
	</div>

	<div class="mx-4 h-px bg-neutral-200/80"></div>

	<div class="px-4 pt-3 pb-4">
		<div class="mb-1.5 flex items-center gap-1.5">
			<svg class="size-3.5 shrink-0 text-blue-600" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden>
				<path d="M3.75 13.5 13.5 3l-1.5 7.5h6.75l-9.75 10.5 1.5-7.5H3.75z" />
			</svg>
			<span class="text-[11px] font-semibold tracking-wider text-neutral-500 uppercase">Now</span>
		</div>
		<p class="text-sm leading-relaxed text-neutral-800">
			Building project dashboard summary card.
		</p>
		<div class="mt-2 flex items-center gap-2 text-xs text-neutral-500">
			<span class="font-medium text-neutral-700">slashtalk</span>
			<span class="text-neutral-300">·</span>
			<span class="font-mono text-[11px] text-neutral-600">main</span>
			<span class="text-neutral-300">·</span>
			<span>14m</span>
		</div>
	</div>

	<div class="mx-4 h-px bg-neutral-200/80"></div>

	<div class="px-4 pt-3 pb-4">
		<div class="mb-1.5 flex items-center gap-1.5">
			<svg class="size-3.5 shrink-0 text-neutral-500" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden>
				<circle cx="12" cy="12" r="9" />
				<path d="M12 7v5l3 2" />
			</svg>
			<span class="text-[11px] font-semibold tracking-wider text-neutral-500 uppercase">Today</span>
		</div>
		<p class="text-sm leading-relaxed text-neutral-800">
			Merged domain-extraction refactor across 4 PRs.
		</p>
	</div>

	<div class="mx-4 h-px bg-neutral-200/80"></div>

	<div class="px-4 pt-3 pb-4">
		<div class="mb-2 text-[11px] font-semibold tracking-wider text-neutral-500 uppercase">
			PRs in review
		</div>
		<div class="space-y-1">
			{
				prs.map((pr) => (
					<div class="flex items-start gap-2 rounded-lg px-2 py-2 hover:bg-neutral-50">
						<svg class={`mt-0.5 size-4 shrink-0 ${stateColor[pr.state]}`} viewBox="0 0 16 16" fill="currentColor" aria-hidden>
							<path d="M1.5 3.25a2.25 2.25 0 1 1 3 2.122v5.256a2.251 2.251 0 1 1-1.5 0V5.372A2.25 2.25 0 0 1 1.5 3.25Zm5.677-.177L9.573.677A.25.25 0 0 1 10 .854V2.5h1A2.5 2.5 0 0 1 13.5 5v5.628a2.251 2.251 0 1 1-1.5 0V5a1 1 0 0 0-1-1h-1v1.646a.25.25 0 0 1-.427.177L7.177 3.427a.25.25 0 0 1 0-.354ZM3.75 2.5a.75.75 0 1 0 0 1.5.75.75 0 0 0 0-1.5Zm0 9.5a.75.75 0 1 0 0 1.5.75.75 0 0 0 0-1.5Zm8.25.75a.75.75 0 1 0 1.5 0 .75.75 0 0 0-1.5 0Z" />
						</svg>
						<div class="min-w-0 flex-1">
							<div class="truncate text-sm text-neutral-800">{pr.title}</div>
							<div class="mt-0.5 flex items-center gap-1.5 text-[11px] text-neutral-500">
								<span class={`font-mono ${stateColor[pr.state]}`}>#{pr.number}</span>
								<span class="text-neutral-300">·</span>
								<span>{pr.state}</span>
								<span class="text-neutral-300">·</span>
								<span>{pr.age}</span>
							</div>
						</div>
					</div>
				))
			}
		</div>
	</div>
</div>
