{
  "name": "slashtalk",
  "version": "0.0.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "packageManager": "bun@1.3.3",
  "engines": {
    "bun": ">=1.3.0"
  },
  "scripts": {
    "dev": "concurrently -k --no-color --names server,desktop \"bun run dev:server\" \"bun run dev:desktop\"",
    "dev:server": "cd apps/server && bun --watch --no-clear-screen src/index.ts",
    "dev:desktop": "cd apps/desktop && bun run dev",
    "dev:web": "cd apps/web && bun run dev",
    "dev:blog": "cd apps/blog && bun run dev",
    "dev:landing": "cd apps/landing && bun run dev",
    "build": "bun --filter @slashtalk/web build && bun --filter @slashtalk/landing build && bun --filter @slashtalk/blog build",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepare": "husky",
    "changeset": "changeset",
    "version": "changeset version && bun install",
    "tag": "changeset tag"
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.9",
    "concurrently": "^9.2.1",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.3"
  }
}
