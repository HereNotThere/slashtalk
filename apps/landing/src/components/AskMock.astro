---
// Static replica of the Ask response window — shortened for the homepage.
---

<div
	class="overflow-hidden rounded-2xl border border-neutral-200 bg-white shadow-[0_30px_60px_-30px_rgba(0,0,0,0.3)]"
>
	<div
		class="relative flex items-center justify-center border-b border-neutral-200 bg-neutral-50 px-4 py-2.5"
	>
		<div class="absolute left-4 flex items-center gap-1.5">
			<span class="size-3 rounded-full bg-[#ff5f57]"></span>
			<span class="size-3 rounded-full bg-[#febc2e]"></span>
			<span class="size-3 rounded-full bg-[#28c840]"></span>
		</div>
		<span class="text-sm font-medium text-neutral-700">Slashtalk</span>
	</div>

	<div
		class="relative flex items-center justify-center border-b border-neutral-200 px-4 py-2.5 text-sm text-neutral-500"
	>
		<button type="button" class="absolute left-4 text-neutral-500 hover:text-neutral-800" aria-label="Open menu">
			<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="18" height="18" aria-hidden="true">
				<path d="M3 6h18M3 12h18M3 18h18"></path>
			</svg>
		</button>
		<span>Ask anything about your team</span>
		<button type="button" class="absolute right-4 text-neutral-500 hover:text-neutral-800" aria-label="Settings">
			<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" width="18" height="18" aria-hidden="true">
				<circle cx="12" cy="12" r="3"></circle>
				<path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 1 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 1 1-4 0v-.09a1.65 1.65 0 0 0-1-1.51 1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 1 1-2.83-2.83l.06-.06a1.65 1.65 0 0 0 .33-1.82 1.65 1.65 0 0 0-1.51-1H3a2 2 0 1 1 0-4h.09a1.65 1.65 0 0 0 1.51-1 1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 1 1 2.83-2.83l.06.06a1.65 1.65 0 0 0 1.82.33H9a1.65 1.65 0 0 0 1-1.51V3a2 2 0 1 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 1 1 2.83 2.83l-.06.06a1.65 1.65 0 0 0-.33 1.82V9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 1 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z"></path>
			</svg>
		</button>
	</div>

	<div class="space-y-4 px-6 py-6 text-sm leading-relaxed text-neutral-800">
		<div class="flex justify-end">
			<div class="max-w-[85%] rounded-2xl bg-neutral-100 px-4 py-2.5 text-neutral-900">
				What's everyone shipping this week?
			</div>
		</div>

		<div class="space-y-2.5">
			<p>
				<strong class="font-semibold text-neutral-900">Theo</strong> — project-level summary card, fixing a merge conflict.
			</p>
			<p>
				<strong class="font-semibold text-neutral-900">Austin</strong> — Claude/Codex quota extraction, addressing review comments.
			</p>
			<p>
				<strong class="font-semibold text-neutral-900">Ryan</strong> — live collision warnings, just landed.
			</p>

			<button
				type="button"
				class="flex w-full items-center gap-3 rounded-xl bg-neutral-50 px-3 py-2.5 text-left transition hover:bg-neutral-100"
			>
				<img
					src="https://i.pravatar.cc/80?img=47"
					alt=""
					class="size-8 shrink-0 rounded-full object-cover"
				/>
				<span class="min-w-0 flex-1">
					<span class="flex items-baseline gap-2">
						<span class="truncate text-sm font-medium text-neutral-900"
							>project-level summary card UI</span
						>
						<span class="size-1.5 shrink-0 animate-pulse rounded-full bg-emerald-500"
						></span>
					</span>
					<span class="block truncate text-[11px] text-neutral-500">
						@ttillberg · main · 15m ago
					</span>
				</span>
			</button>
		</div>
	</div>

	<div class="px-6 pt-2 pb-5">
		<div
			class="flex items-center gap-2 rounded-full border border-neutral-200 bg-white py-2 pr-2 pl-5 transition focus-within:border-neutral-400"
		>
			<input
				type="text"
				placeholder="Ask anything"
				class="flex-1 bg-transparent text-sm text-neutral-900 placeholder:text-neutral-400 focus:outline-none"
			/>
			<button
				type="button"
				class="inline-flex size-8 items-center justify-center rounded-full bg-emerald-500 text-white transition hover:bg-emerald-600"
				aria-label="Send"
			>
				<svg
					viewBox="0 0 24 24"
					fill="none"
					stroke="currentColor"
					stroke-width="2"
					stroke-linecap="round"
					stroke-linejoin="round"
					width="14"
					height="14"
					aria-hidden="true"
				>
					<path d="m5 12 14-7-7 14-2-5-5-2Z"></path>
				</svg>
			</button>
		</div>
	</div>
</div>
