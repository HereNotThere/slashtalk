{
  "name": "slashtalk",
  "private": true,
  "workspaces": ["apps/*", "packages/*"],
  "scripts": {
    "dev": "concurrently -k --no-color --names server,mcp,desktop \"bun run dev:server\" \"bun run dev:mcp\" \"bun run dev:desktop\"",
    "dev:server": "cd apps/server && bun --watch --no-clear-screen src/index.ts",
    "dev:mcp": "cd apps/mcp && bun --watch --no-clear-screen src/index.ts",
    "dev:desktop": "cd apps/desktop && bun run dev"
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}
