---
interface Bubble {
	login: string;
	id: number;
	label: string;
	live?: boolean;
}

// Slashtalk team — top contributors to HereNotThere/slashtalk.
// Avatar URLs are derived from each user's GitHub numeric ID, which never
// changes even if a user renames their account.
// `live` mirrors the desktop's active-session indicator (a pulsing rim).
const bubbles: Bubble[] = [
	{ login: "ttillberg", id: 557990, label: "16m", live: true },
	{ login: "texuf", id: 950745, label: "14m", live: true },
	{ login: "erikolsson", id: 352982, label: "49m" },
	{ login: "giuseppecrj", id: 5714678, label: "1h", live: true },
	{ login: "heyitsfei", id: 1041695, label: "1h" },
	{ login: "benrbn", id: 22621836, label: "6h" },
	{ login: "ryanpaulc1", id: 28305049, label: "13h" },
	{ login: "sergekh2", id: 104387024, label: "23h" },
];

const avatarFor = (id: number) => `https://avatars.githubusercontent.com/u/${id}?s=120&v=4`;
---

<div
	class="inline-flex max-w-full items-center gap-1 overflow-x-auto rounded-full border border-white/60 bg-neutral-200/70 px-2 py-1.5 shadow-[0_10px_40px_-12px_rgba(0,0,0,0.25)] backdrop-blur-md [scrollbar-width:none] sm:gap-2.5 sm:overflow-visible sm:px-3 sm:py-2 [&::-webkit-scrollbar]:hidden"
>
	{
		bubbles.map((b) => (
			<a
				href={`https://github.com/${b.login}`}
				target="_blank"
				rel="noopener"
				aria-label={`@${b.login}${b.live ? " — live coding session" : ""} — last active ${b.label || "recently"}`}
				class={`relative inline-flex size-8 shrink-0 items-center justify-center rounded-full bg-neutral-300 ring-1 ring-black/5 transition hover:scale-110 sm:size-[52px] ${b.live ? "dock-live" : ""}`}
			>
				<img
					src={avatarFor(b.id)}
					alt=""
					decoding="async"
					fetchpriority="high"
					class="size-full rounded-full object-cover"
				/>
				{b.label && (
					<span class="absolute -right-1 -bottom-1 rounded-full bg-neutral-900/90 px-1 py-0.5 text-[8px] leading-none font-medium text-white shadow-sm ring-2 ring-neutral-200/70 sm:px-1.5 sm:text-[10px]">
						{b.label}
					</span>
				)}
			</a>
		))
	}
	<button
		type="button"
		aria-label="Search the dock"
		class="inline-flex size-8 shrink-0 items-center justify-center rounded-full bg-neutral-300/80 text-neutral-700 transition hover:bg-neutral-300 sm:size-[52px]"
	>
		<svg
			viewBox="0 0 24 24"
			fill="none"
			stroke="currentColor"
			stroke-width="2"
			stroke-linecap="round"
			stroke-linejoin="round"
			width="16"
			height="16"
			aria-hidden="true"
			class="sm:[&]:size-5"
		>
			<circle cx="11" cy="11" r="7"></circle>
			<path d="m20 20-3.5-3.5"></path>
		</svg>
	</button>
</div>

<style>
	.dock-live {
		box-shadow: 0 0 0 2px rgba(59, 130, 246, 0.9);
		animation: dock-live-pulse 2s ease-in-out infinite;
	}

	@keyframes dock-live-pulse {
		0%,
		100% {
			box-shadow: 0 0 0 2px rgba(59, 130, 246, 0.9);
		}
		50% {
			box-shadow: 0 0 0 4px rgba(59, 130, 246, 0.9);
		}
	}

	@media (prefers-reduced-motion: reduce) {
		.dock-live {
			animation: none;
		}
	}
</style>
